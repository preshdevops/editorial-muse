# ─── SERVER ───────────────────────────────────────
PORT=3000

# ─── EMAIL  (Gmail example — use an App Password) ──
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Generate a password and paste below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="The Editorial Muse <your@gmail.com>"

# ─── WHATSAPP (Twilio) ────────────────────────────
# Sign up at twilio.com → get a WhatsApp sandbox number
# Your Twilio credentials from console.twilio.com/dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── FRONTEND URL (for share links) ──────────────
APP_URL=http://localhost:3000
